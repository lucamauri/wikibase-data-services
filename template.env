# =============================================================================
# DataTrekServices — Environment Configuration Template
# =============================================================================
#
# USAGE
#   cp template.env .env
#   Fill in your values, then run: docker compose up -d
#
#   .env is gitignored and never committed.
#   This template IS committed — it documents every required variable.
#
# WARNING
#   Do not add inline comments after variable values — in some environments
#   they are included in the variable content and will break things.
#
# =============================================================================


# -----------------------------------------------------------------------------
# WIKIBASE — your existing host-based Wikibase installation
# -----------------------------------------------------------------------------

# Public hostname of your Wikibase instance (no scheme, no trailing slash).
# Example: data.wikitrek.org
WIKIBASE_HOST=

# Public scheme for your Wikibase instance (almost always https in production).
WIKIBASE_PUBLIC_SCHEME=https

# Scheme the WDQS updater uses internally to reach the Wikibase API.
# Use https if Apache serves Wikibase over HTTPS (normal production setup).
WIKIBASE_SCHEME=https

# Path to the Wikibase API script (including leading slash).
# Example for a wiki at /dt/ : /dt/api.php
# Example for a wiki at /w/  : /w/api.php
WIKIBASE_API_PATH=

# Concept URI — the RDF namespace prefix for all Wikibase entities.
# Must match $wgServer in your Wikibase LocalSettings.php exactly,
# including scheme. No trailing slash.
# Example: https://data.wikitrek.org
WIKIBASE_CONCEPT_URI=

# Wikibase entity namespace IDs for the WDQS updater.
# 120=Item, 146=Property are correct for standard Wikibase.
# Only change if you have customised your namespace configuration.
WIKIBASE_ENTITY_NAMESPACES=120,146


# -----------------------------------------------------------------------------
# WDQS Frontend — public SPARQL query interface
# -----------------------------------------------------------------------------

# Public hostname where the SPARQL query UI will be served.
# Your host reverse proxy must forward requests for this hostname to Traefik.
# Example: query.wikitrek.org
WDQS_PUBLIC_HOST=

# Public scheme for the WDQS frontend.
WDQS_PUBLIC_SCHEME=https


# -----------------------------------------------------------------------------
# QuickStatements — public batch editing tool
# -----------------------------------------------------------------------------

# Public hostname where QuickStatements will be served.
# Your host reverse proxy must forward requests for this hostname to Traefik.
# Example: qs.wikitrek.org
QUICKSTATEMENTS_PUBLIC_HOST=

# Public scheme for QuickStatements.
QUICKSTATEMENTS_PUBLIC_SCHEME=https


# -----------------------------------------------------------------------------
# Elasticsearch — search backend (accessed by host MediaWiki, not publicly)
# -----------------------------------------------------------------------------

# Host port Elasticsearch binds to on 127.0.0.1.
# In LocalSettings.php set $wgCirrusSearchServers = [ '127.0.0.1' ];
# If you change this from 9200, also set $wgCirrusSearchPort accordingly.
ELASTICSEARCH_HOST_PORT=9200


# -----------------------------------------------------------------------------
# Traefik — internal reverse proxy
# -----------------------------------------------------------------------------

# Interface Traefik binds to on the host.
#
#   127.0.0.1  (recommended) — only the host machine can reach Traefik.
#              Use when Apache, Nginx, Caddy or similar handles public traffic.
#
#   0.0.0.0    — Traefik is reachable from outside the server.
#              Use for standalone deployments without a host reverse proxy.
#
TRAEFIK_BIND_ADDRESS=127.0.0.1

# Port Traefik listens on (on the interface above).
# Your reverse proxy must forward to this port.
# Example Apache directive: ProxyPass / http://127.0.0.1:8880/
# Default 8880 avoids conflicts with Apache (:80) and common dev tools.
TRAEFIK_HOST_PORT=8880


# -----------------------------------------------------------------------------
# WDQS Frontend branding (used in config/wdqs-frontend-custom-config.json)
# -----------------------------------------------------------------------------

# Short display name for your Wikibase instance (used in the UI title bar).
# Example: DataTrek
WIKIBASE_NAME=

# Public URL of your Wikibase logo image.
# Example: https://data.wikitrek.org/dt/resources/assets/wiki.png
WIKIBASE_LOGO=

# Public URL of your Wikibase favicon.
# Example: https://data.wikitrek.org/dt/resources/assets/favicon.ico
WIKIBASE_FAVICON=

# Public URL of your copyright/about page.
# Example: https://data.wikitrek.org/wiki/WikiTrek:Informazioni
WIKIBASE_COPYRIGHT=

# Title of the wiki page containing SPARQL query examples.
# The page must exist on your Wikibase instance.
# Example: Help:Esempi_query_SPARQL
WIKIBASE_EXAMPLES_PAGE_TITLE=
