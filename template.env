# ==============================================================================
# template.env — wikibase-data-services
#
# Copy this file to .env and fill in your values.
#
#   cp template.env .env
#   nano .env
#
# The .env file is gitignored and must NEVER be committed — it contains
# credentials and site-specific values.
#
# WARNING: Do not add inline comments on the same line as a variable value.
# In some environments the comment text will be included in the value itself,
# causing subtle and hard-to-debug failures.
#
# NOTE: WIKIBASE_CONCEPT_URI is intentionally absent from this file.
# It is assembled automatically in docker-compose.yml as:
#   ${WIKIBASE_SCHEME}://${WIKIBASE_HOST}/
# Setting it here (especially with a /entity/ suffix) causes a
# BadSubjectException in the WDQS updater Munger. Do not add it.
# ==============================================================================


# ------------------------------------------------------------------------------
# Public hostnames
# ------------------------------------------------------------------------------
# These must match your DNS records exactly.
# Each value must also appear as the ServerName in the corresponding
# Apache VirtualHost (or equivalent in your reverse proxy).
# All three must be distinct hostnames — they cannot share a hostname.
#
# WDQS_FRONTEND_PUBLIC_HOST  : the SPARQL query UI
# QUICKSTATEMENTS_PUBLIC_HOST: the batch editing tool
# ------------------------------------------------------------------------------
WDQS_FRONTEND_PUBLIC_HOST=query.example.org
QUICKSTATEMENTS_PUBLIC_HOST=qs.example.org


# ------------------------------------------------------------------------------
# Wikibase connection
# ------------------------------------------------------------------------------
# How the containers reach your existing Wikibase installation.
#
# WIKIBASE_SCHEME : the protocol your Wikibase is served over.
#                   Use https for any production deployment.
#
# WIKIBASE_HOST   : public hostname of your Wikibase (no scheme, no trailing
#                   slash). The updater reaches Wikibase through public DNS,
#                   exactly like an external client.
#
# WIKIBASE_API_PATH: path to api.php on your Wikibase host.
#                   Standard MediaWiki install : /w/api.php
#                   Custom install (e.g. subfolder): /dt/api.php
#                   Check your MediaWiki installation if unsure.
#
# WIKIBASE_ENTITY_NAMESPACES: MediaWiki namespace IDs for Wikibase entity types.
#                   Standard self-hosted Wikibase: 120 (Item), 122 (Property).
#                   WARNING: 146 is Wikidata-specific — do NOT use it for a
#                   self-hosted instance; it will cause the updater to miss
#                   all entity changes.
#
# WDQS_PUBLIC_HOST: public hostname of the SPARQL endpoint, used by the updater
#                   to verify connectivity. Normally identical to
#                   WDQS_FRONTEND_PUBLIC_HOST.
# ------------------------------------------------------------------------------
WIKIBASE_SCHEME=https
WIKIBASE_HOST=data.example.org
WIKIBASE_API_PATH=/w/api.php
WIKIBASE_ENTITY_NAMESPACES=120,122
WDQS_PUBLIC_HOST=query.example.org


# ------------------------------------------------------------------------------
# WDQS Frontend branding
# ------------------------------------------------------------------------------
# These values customise the appearance of the SPARQL query UI.
#
# WIKIBASE_NAME        : short display name shown in the UI title bar.
# WIKIBASE_LOGO        : full URL to your wiki's logo image.
# WIKIBASE_FAVICON     : full URL to your wiki's favicon.
# WIKIBASE_COPYRIGHT   : full URL to your wiki's copyright / about page,
#                        linked from the UI footer.
# WIKIBASE_EXAMPLES_PAGE: MediaWiki page title (not full URL) of a wiki page
#                        containing SPARQL query examples, e.g.:
#                        Help:SPARQL_query_examples
# ------------------------------------------------------------------------------
WIKIBASE_NAME=My Wikibase
WIKIBASE_LOGO=https://data.example.org/path/to/logo.svg
WIKIBASE_FAVICON=https://data.example.org/path/to/favicon.ico
WIKIBASE_COPYRIGHT=https://data.example.org/wiki/Project:About
WIKIBASE_EXAMPLES_PAGE=Help:SPARQL_query_examples


# ------------------------------------------------------------------------------
# QuickStatements OAuth credentials
# ------------------------------------------------------------------------------
# QuickStatements authenticates users via OAuth 1.0a against your Wikibase.
# You must register an OAuth consumer on your wiki before first use.
#
# Step-by-step registration guide: docs/quickstatements-oauth-setup.md
#
# OAUTH_CONSUMER_KEY   : the key assigned during consumer registration.
# OAUTH_CONSUMER_SECRET: the secret assigned during consumer registration.
# OAUTH_SCRIPT_PATH    : base URL of your Wikibase wiki root (no trailing slash).
#                        Used to build the OAuth endpoint URLs, e.g.:
#                        https://data.example.org/w
#                        (the stack appends /index.php?title=Special:OAuth)
# ------------------------------------------------------------------------------
OAUTH_CONSUMER_KEY=your_consumer_key_here
OAUTH_CONSUMER_SECRET=your_consumer_secret_here
OAUTH_SCRIPT_PATH=https://data.example.org/w


# ------------------------------------------------------------------------------
# QuickStatements batch database credentials
# ------------------------------------------------------------------------------
# QuickStatements uses two MariaDB databases on the host for batch job tracking.
# These credentials must match the MariaDB user you created on the host.
#
# Host-side setup required (see docs/adr-quickstatements-batch-fix.md):
#   - MariaDB must listen on 172.18.0.1 (the Docker bridge gateway)
#   - UFW must allow 172.18.0.0/16 → port 3306
#   - Two databases must exist:
#       qsbot__quickstatements_p
#       qsbot__quickstatements_auth
#   - A MariaDB user must have GRANT ALL on both databases
#     from the 172.18.0.% host pattern
#
# QS_DB_USER    : MariaDB username for the batch databases.
# QS_DB_PASSWORD: MariaDB password for that user.
# ------------------------------------------------------------------------------
QS_DB_USER=qsbot
QS_DB_PASSWORD=your_strong_password_here


# ------------------------------------------------------------------------------
# Infrastructure
# ------------------------------------------------------------------------------
# TRAEFIK_BIND_ADDRESS: the IP address Traefik listens on for incoming HTTP.
#
#   127.0.0.1 (default, recommended for production)
#     Use when a host-level reverse proxy (Apache, Nginx, Caddy) handles
#     public TLS and forwards traffic to Traefik on this loopback address.
#     Traefik is not directly reachable from the internet in this mode.
#     See docs/apache-integration.md for Apache vhost examples.
#
#   0.0.0.0 (standalone mode)
#     Use only if you have no host reverse proxy and want Traefik to be
#     directly reachable. You are responsible for TLS in this case.
#
# TRAEFIK_HOST_PORT: host port that Traefik's HTTP entrypoint is mapped to.
#   Default 8880. Your reverse proxy must proxy to this port.
#   Change only if 8880 conflicts with another service on your host.
#
# ELASTICSEARCH_HOST_PORT: host port for the Elasticsearch HTTP API.
#   Default 9200. MediaWiki CirrusSearch connects to this port on 127.0.0.1.
#   Change only if 9200 is already in use on your host.
# ------------------------------------------------------------------------------
TRAEFIK_BIND_ADDRESS=127.0.0.1
TRAEFIK_HOST_PORT=8880
ELASTICSEARCH_HOST_PORT=9200


# ------------------------------------------------------------------------------
# WDQS Updater polling interval
# ------------------------------------------------------------------------------
# How often (in SECONDS) the updater checks Wikibase for new changes and
# pushes them into Blazegraph.
#
# Unit: SECONDS (not milliseconds — the upstream default of 10 is also seconds).
#
# Guidance:
#   10  : upstream default; suitable for high-traffic wikis needing near-
#         real-time SPARQL results.
#   60  : recommended for most self-hosted wikis; reduces unnecessary load
#         on both Wikibase and Blazegraph.
#   120+: acceptable for wikis with infrequent edits.
# ------------------------------------------------------------------------------
UPDATER_DELAY=60