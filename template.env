# ==============================================================================
# template.env — wikibase-data-services
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored and must NEVER be committed.
#
# WARNING: Do not add inline comments on the same line as env vars —
# in some environments they will be included in the variable value.
# ==============================================================================

# ------------------------------------------------------------------------------
# Public hostnames
# These must match your DNS records and Apache vhost ServerName directives.
# All three must be distinct subdomains.
# ------------------------------------------------------------------------------
WIKIBASE_PUBLIC_HOST=wikibase.example
WDQS_FRONTEND_PUBLIC_HOST=query.example
QUICKSTATEMENTS_PUBLIC_HOST=qs.example

# ------------------------------------------------------------------------------
# Wikibase connection
# Used by wdqs-updater and quickstatements to reach your Wikibase instance.
# WIKIBASE_HOST must be the public hostname (resolved via DNS).
# WIKIBASE_API_PATH is the path to api.php (e.g. /w/api.php or /dt/api.php).
# WIKIBASE_CONCEPT_URI is the base URI for your entities.
# WIKIBASE_ENTITY_NAMESPACES are the MediaWiki namespace IDs for items and properties.
# ------------------------------------------------------------------------------
WIKIBASE_SCHEME=https
WIKIBASE_HOST=data.example.org
WIKIBASE_API_PATH=/w/api.php
WIKIBASE_CONCEPT_URI=https://data.example.org/entity/
WIKIBASE_ENTITY_NAMESPACES=120,146

# ------------------------------------------------------------------------------
# WDQS (Blazegraph) public endpoint
# Used by wdqs-updater to verify the SPARQL endpoint is reachable.
# Usually the same value as WDQS_FRONTEND_PUBLIC_HOST.
# ------------------------------------------------------------------------------
WDQS_PUBLIC_HOST=query.example.org

# ------------------------------------------------------------------------------
# WDQS Frontend branding
# Customises the query UI appearance and links.
# ------------------------------------------------------------------------------
WIKIBASE_NAME=ShortName
WIKIBASE_URI=https://data.example.org/
WIKIBASE_LOGO=https://data.example.org/path/to/logo.svg
WIKIBASE_FAVICON=https://data.example.org/path/to/favicon.ico
WIKIBASE_COPYRIGHT=https://data.example.org/wiki/Project:About
WIKIBASE_EXAMPLES_PAGE=Help:SPARQL_query_examples

# ------------------------------------------------------------------------------
# QuickStatements OAuth credentials
# Register a consumer at Special:OAuthConsumerRegistration on your Wikibase.
# OAUTH_SCRIPT_PATH is the base URL of your Wikibase (without trailing slash),
# used to build the OAuth endpoint URLs.
# ------------------------------------------------------------------------------
OAUTH_CONSUMER_KEY=your_consumer_key_here
OAUTH_CONSUMER_SECRET=your_consumer_secret_here
OAUTH_SCRIPT_PATH=https://data.example.org/w

# ------------------------------------------------------------------------------
# Infrastructure
# TRAEFIK_BIND_ADDRESS: use 127.0.0.1 when Apache+Anubis handles public TLS
# (recommended for production). Use 0.0.0.0 only for standalone deployments.
# ------------------------------------------------------------------------------
TRAEFIK_BIND_ADDRESS=127.0.0.1
TRAEFIK_HOST_PORT=8880
ELASTICSEARCH_HOST_PORT=9200